{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matthewsreview/schema-v1.json",
  "title": "matthewsreview artifact (v1)",
  "description": "Canonical machine-state artifact produced by matthewsreview review commands and mutated across the add, walkthrough, promote, and fix lifecycle. Codifies the state model and artifact contract documented in docs/state-and-gates.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "generated_at",
    "review_started_at",
    "reviewed_sha",
    "base_branch",
    "head_branch",
    "mode",
    "pr_state",
    "pr_number",
    "comment_id",
    "trivial_mode",
    "reviewer_sources",
    "reviewed_files_all",
    "claude_md_paths",
    "findings",
    "cross_cutting_groups",
    "subagent_tokens",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "review_id": {
      "type": "string",
      "pattern": "^rev_[A-Za-z0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "base_branch": { "type": "string", "minLength": 1 },
    "head_branch": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["pr", "local"] },
    "pr_state": {
      "anyOf": [
        { "enum": ["draft", "open"] },
        { "type": "null" }
      ]
    },
    "pr_number": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "comment_id": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "trivial_mode": { "type": "boolean" },
    "reviewer_sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewed_files_all": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "claude_md_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "cross_cutting_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/cross_cutting_group" }
    },
    "subagent_tokens": { "$ref": "#/$defs/subagent_tokens" },
    "orchestrator_tokens": { "$ref": "#/$defs/orchestrator_tokens" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "base_context": { "$ref": "#/$defs/base_context" },
    "model_plan": { "$ref": "#/$defs/model_plan" },
    "gates": {
      "anyOf": [
        { "$ref": "#/$defs/gates" },
        { "type": "null" }
      ]
    },
    "degraded": { "$ref": "#/$defs/degraded" }
  },

  "$defs": {
    "model_plan": {
      "description": "Resolved per-role model plan for the current lifecycle command, written by review-config.sh at Phase 0 (review) / load time (fix, add, walkthrough, promote). Optional — pre-v1.0 artifacts omit it. Each command re-resolves fresh; the field reflects the most recent invocation.",
      "type": "object",
      "additionalProperties": false,
      "required": ["orchestrator", "roles", "gates", "warnings"],
      "properties": {
        "orchestrator": { "enum": ["claude-code", "omp", "codex"] },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "deep_lens", "deep_validate", "cross_cutting", "fix",
            "post_fix_review", "reconcile", "light_lens", "light_validate",
            "classifier", "normalizer", "dedup", "scoring", "fix_hint",
            "briefer", "drafter", "ensemble_detect", "codex_detect",
            "codex_validate", "codex_crosscut"
          ],
          "properties": {
            "deep_lens": { "$ref": "#/$defs/model_role" },
            "deep_validate": { "$ref": "#/$defs/model_role" },
            "cross_cutting": { "$ref": "#/$defs/model_role" },
            "fix": { "$ref": "#/$defs/model_role" },
            "post_fix_review": { "$ref": "#/$defs/model_role" },
            "reconcile": { "$ref": "#/$defs/model_role" },
            "light_lens": { "$ref": "#/$defs/model_role" },
            "light_validate": { "$ref": "#/$defs/model_role" },
            "classifier": { "$ref": "#/$defs/model_role" },
            "normalizer": { "$ref": "#/$defs/model_role" },
            "dedup": { "$ref": "#/$defs/model_role" },
            "scoring": { "$ref": "#/$defs/model_role" },
            "fix_hint": { "$ref": "#/$defs/model_role" },
            "briefer": { "$ref": "#/$defs/model_role" },
            "drafter": { "$ref": "#/$defs/model_role" },
            "ensemble_detect": { "$ref": "#/$defs/model_role" },
            "codex_detect": { "$ref": "#/$defs/model_role" },
            "codex_validate": { "$ref": "#/$defs/model_role" },
            "codex_crosscut": { "$ref": "#/$defs/model_role" }
          }
        },
        "gates": {
          "anyOf": [
            { "$ref": "#/$defs/gates" },
            { "type": "null" }
          ]
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "model_role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "model", "effort", "source"],
      "properties": {
        "engine": { "enum": ["claude", "codex", "omp"] },
        "model": { "type": "string" },
        "effort": {
          "anyOf": [
            { "type": "null" },
            { "enum": ["off", "minimal", "low", "medium", "high", "xhigh", "max", "ultra"] }
          ]
        },
        "source": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "engine": { "const": "claude" } },
            "required": ["engine"]
          },
          "then": {
            "properties": {
              "model": { "type": "string", "minLength": 1 },
              "effort": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "engine": { "const": "codex" } },
            "required": ["engine"]
          },
          "then": {
            "properties": {
              "effort": {
                "anyOf": [
                  { "type": "null" },
                  { "enum": ["low", "medium", "high", "xhigh", "max", "ultra"] }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "engine": { "const": "omp" } },
            "required": ["engine"]
          },
          "then": {
            "properties": {
              "model": { "type": "string", "minLength": 1 },
              "effort": {
                "anyOf": [
                  { "type": "null" },
                  { "enum": ["off", "minimal", "low", "medium", "high", "xhigh", "max"] }
                ]
              }
            }
          }
        }
      ]
    },
    "degraded": {
      "description": "Persistent partial-coverage marker. Any positive lens-dispatch, candidate-loss, or finalization failure count makes the run degraded and produces a prominent renderer banner. Optional fields preserve compatibility with artifacts created before a failure class was tracked.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lens_dispatch_failures": { "type": "integer", "minimum": 0 },
        "candidate_drop_failures": { "type": "integer", "minimum": 0 },
        "finalization_failures": { "type": "integer", "minimum": 0 }
      },
      "anyOf": [
        {
          "required": ["lens_dispatch_failures"],
          "properties": {
            "lens_dispatch_failures": { "minimum": 1 }
          }
        },
        {
          "required": ["candidate_drop_failures"],
          "properties": {
            "candidate_drop_failures": { "minimum": 1 }
          }
        },
        {
          "required": ["finalization_failures"],
          "properties": {
            "finalization_failures": { "minimum": 1 }
          }
        }
      ]
    },
    "gates": {
      "description": "Resolved gate thresholds for this run. Optional — absent means built-in defaults (45 / 45-60-75 / 60 / 60).",
      "type": "object",
      "additionalProperties": false,
      "required": ["phase3_gate", "phase4_bands", "fix_threshold", "walkthrough_threshold"],
      "properties": {
        "phase3_gate": { "type": "number", "minimum": 0, "maximum": 100 },
        "phase4_bands": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "fix_threshold": { "type": "number", "minimum": 0, "maximum": 100 },
        "walkthrough_threshold": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "base_context": {
      "description": "§13.10 base-branch freshness record. Optional — absent from pre-§13.10 artifacts.",
      "type": "object",
      "additionalProperties": false,
      "required": ["freshness", "comparison_ref"],
      "properties": {
        "freshness": {
          "enum": ["fresh", "fast_forwarded", "used_remote_ref", "proceeded_stale", "no_fetch", "no_remote"]
        },
        "comparison_ref": { "type": "string", "minLength": 1 },
        "remote_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            { "type": "null" }
          ]
        },
        "behind_count": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        }
      }
    },
    "disposition_enum": {
      "enum": [
        "below_gate",
        "pending_validation",
        "disproven",
        "uncertain",
        "confirmed_mechanical",
        "confirmed_manual",
        "confirmed_report",
        "pre_existing_report",
        "partial",
        "regression",
        "resolved"
      ]
    },
    "current_state_enum": {
      "enum": ["open", "attempted", "resolved"]
    },
    "impact_type_enum": {
      "enum": ["correctness", "security", "ux", "policy", "architecture"]
    },
    "origin_enum": {
      "enum": ["introduced_by_pr", "pre_existing", "unknown"]
    },
    "origin_confidence_enum": {
      "enum": ["high", "medium", "low"]
    },
    "actionability_enum": {
      "enum": ["auto_fixable", "manual", "report_only"]
    },
    "validation_lane_enum": {
      "enum": ["deep", "light"]
    },
    "confirmed_strength_enum": {
      "enum": ["moderate", "strong"]
    },
    "phase_9_outcome_enum": {
      "enum": ["verified", "partial", "regression"]
    },
    "score_phase_enum": {
      "enum": [
        "phase_3",
        "phase_4",
        "phase_4a",
        "phase_4b"
      ]
    },

    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sources",
        "source_families",
        "impact_type",
        "origin",
        "origin_confidence",
        "actionability",
        "validation_lane",
        "current_state",
        "disposition",
        "is_actionable",
        "reason",
        "confirmed_strength",
        "file",
        "line_range",
        "claim",
        "score_phase3",
        "score_phase4",
        "score_history",
        "validation_result",
        "fix_attempts",
        "introduced_in_sha",
        "suggested_follow_up",
        "related_parent_finding_id"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^F[0-9]+$" },
        "sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_families": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "impact_type": { "$ref": "#/$defs/impact_type_enum" },
        "origin": { "$ref": "#/$defs/origin_enum" },
        "origin_confidence": { "$ref": "#/$defs/origin_confidence_enum" },
        "actionability": { "$ref": "#/$defs/actionability_enum" },
        "validation_lane": { "$ref": "#/$defs/validation_lane_enum" },
        "current_state": { "$ref": "#/$defs/current_state_enum" },
        "disposition": { "$ref": "#/$defs/disposition_enum" },
        "is_actionable": { "type": "boolean" },
        "reason": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "confirmed_strength": {
          "anyOf": [
            { "$ref": "#/$defs/confirmed_strength_enum" },
            { "type": "null" }
          ]
        },
        "file": { "type": "string", "minLength": 1 },
        "line_range": {
          "description": "File-absolute inclusive source range, or null when the source did not provide a trustworthy line. Null must remain unknown; callers must not fabricate line 1.",
          "anyOf": [
            {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 },
              "minItems": 2,
              "maxItems": 2
            },
            { "type": "null" }
          ]
        },
        "claim": { "type": "string", "minLength": 1 },
        "score_phase3": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "score_phase4": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "score_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "score"],
            "properties": {
              "phase": { "$ref": "#/$defs/score_phase_enum" },
              "score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "validation_result": {
          "anyOf": [
            { "$ref": "#/$defs/validation_result" },
            { "type": "null" }
          ]
        },
        "auto_fix_hint": {
          "description": "Set by Phase 5.5 (auto-fix-hint generation). Validator-derived recommendation that mirrors what /matthewsreview:walkthrough's per-finding briefer would produce, but pre-computed with a second-opinion verification pass. When present, /matthewsreview:fix preflight and /matthewsreview:walkthrough Step 4.5 surface a batch-confirm UI that promotes the finding via human_confirmation.fix_hint=auto_fix_hint.hint. Optional — absence means no auto-rec was generated for this finding (ineligible per §5.5 filter, or generation skipped/failed).",
          "type": "object",
          "additionalProperties": false,
          "required": ["hint", "confidence", "second_opinion", "ts"],
          "properties": {
            "hint": { "type": "string", "minLength": 1 },
            "confidence": { "enum": ["high", "medium", "low"] },
            "second_opinion": { "enum": ["concurs", "concerns"] },
            "concerns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "alternatives": {
              "type": "array",
              "maxItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["label", "title", "hint"],
                "properties": {
                  "label": { "type": "string" },
                  "title": { "type": "string" },
                  "hint":  { "type": "string", "minLength": 1 }
                }
              }
            },
            "ts": { "type": "string", "format": "date-time" }
          }
        },
        "fix_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fix_attempt" }
        },
        "introduced_in_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            { "type": "null" }
          ]
        },
        "suggested_follow_up": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "related_parent_finding_id": {
          "anyOf": [
            { "type": "string", "pattern": "^F[0-9]+$" },
            { "type": "null" }
          ]
        },
        "human_confirmation": {
          "description": "Set by /matthewsreview:promote. Present-and-non-null means a human has promoted this finding to auto-fixable; Phase 8 eligibility (§5.2.1) bypasses the impact_type lane filter and score threshold. Optional/nullable — pre-promote findings omit the field entirely.",
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["reviewer", "reason", "ts", "promoted_from"],
              "properties": {
                "reviewer": { "type": "string", "minLength": 1 },
                "reason":   { "type": "string", "minLength": 1 },
                "ts":       { "type": "string", "format": "date-time" },
                "promoted_from": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["disposition", "actionability", "score_phase4"],
                  "properties": {
                    "disposition":   { "$ref": "#/$defs/disposition_enum" },
                    "actionability": { "$ref": "#/$defs/actionability_enum" },
                    "score_phase4": {
                      "anyOf": [
                        { "type": "integer", "minimum": 0, "maximum": 100 },
                        { "type": "null" }
                      ]
                    }
                  }
                },
                "fix_hint": {
                  "description": "Optional human-authored steering hint surfaced to the Phase 8 fix-group agent (§19.8). Resolves ambiguity in light-lane promotions where validation_result.fix_proposal is null and the claim alone doesn't tell the fix agent which side of a code/text mismatch to change. Distinct from `reason` — `reason` is audit-focused (why I promoted); `fix_hint` is instruction-focused (how to fix). Optional; absent or null means no hint.",
                  "anyOf": [
                    { "type": "null" },
                    { "type": "string", "minLength": 1 }
                  ]
                }
              }
            }
          ]
        }
      }
    },

    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "blast_radius",
        "fix_proposal",
        "verification_context"
      ],
      "properties": {
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blast_radius": {
          "type": "object",
          "additionalProperties": false,
          "required": ["writers", "consumers", "parallel_paths", "invariants_at_stake"],
          "properties": {
            "writers": { "type": "array", "items": { "type": "string" } },
            "consumers": { "type": "array", "items": { "type": "string" } },
            "parallel_paths": { "type": "array", "items": { "type": "string" } },
            "invariants_at_stake": { "type": "array", "items": { "type": "string" } }
          }
        },
        "fix_proposal": { "$ref": "#/$defs/fix_proposal" },
        "verification_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "how_to_verify_fix",
            "edge_cases_to_preserve",
            "what_would_break_if_incomplete"
          ],
          "properties": {
            "how_to_verify_fix": { "type": "array", "items": { "type": "string" } },
            "edge_cases_to_preserve": { "type": "array", "items": { "type": "string" } },
            "what_would_break_if_incomplete": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "fix_proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approach", "files_to_modify"],
      "properties": {
        "approach": { "type": "string", "minLength": 1 },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "what", "why"],
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "what": { "type": "string" },
              "why": { "type": "string" }
            }
          }
        }
      }
    },

    "fix_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "timestamp",
        "fix_group_id",
        "input_sha",
        "output_sha",
        "phase_9_outcome"
      ],
      "properties": {
        "run_id": { "type": "string", "pattern": "^fixrun_[A-Za-z0-9]+$" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fix_group_id": { "type": "string", "pattern": "^FG-[0-9]+$" },
        "input_sha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
        "output_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            { "type": "null" }
          ]
        },
        "phase_9_outcome": {
          "anyOf": [
            { "$ref": "#/$defs/phase_9_outcome_enum" },
            { "type": "null" }
          ]
        },
        "phase_9_finding": { "type": "string" },
        "revised_fix_proposal": { "$ref": "#/$defs/fix_proposal" }
      }
    },

    "cross_cutting_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "finding_ids", "combined_approach"],
      "properties": {
        "id": { "type": "string", "pattern": "^G[0-9]+$" },
        "finding_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F[0-9]+$" },
          "minItems": 2,
          "uniqueItems": true
        },
        "combined_approach": { "type": "string", "minLength": 1 }
      }
    },

    "subagent_tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "invocations", "by_phase", "by_model", "by_lens", "by_finding_phase4"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "invocations": { "type": "integer", "minimum": 0 },
        "by_phase": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_model": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_lens": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_finding_phase4": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "orchestrator_tokens": {
      "description": "Main-session (orchestrator) token spend for the Claude Code sessions that ran this review lifecycle. orchestrator-tokens.sh reads only the active SessionStart transcript, replaces that session's prior counters, and retains counters already recorded for other lifecycle sessions. Populated at Phase 6 finalize and at every lifecycle-command terminus. Optional — absent means the helper hasn't run yet (pre-feature artifacts, an interrupted run, or tally opt-out). The four input/output/cache counters are preserved separately because their $/token pricing differs materially (cache-read is ~10x cheaper than fresh input).",
      "type": "object",
      "additionalProperties": false,
      "required": ["total_input", "total_output", "cache_read", "cache_creation", "turn_count", "sessions"],
      "properties": {
        "total_input": { "type": "integer", "minimum": 0 },
        "total_output": { "type": "integer", "minimum": 0 },
        "cache_read": { "type": "integer", "minimum": 0 },
        "cache_creation": { "type": "integer", "minimum": 0 },
        "turn_count": { "type": "integer", "minimum": 0 },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["session_id", "transcript_path", "first_seen", "last_seen", "turn_count"],
            "properties": {
              "session_id": { "type": "string", "minLength": 1 },
              "transcript_path": { "type": "string", "minLength": 1 },
              "first_seen": { "type": "string", "format": "date-time" },
              "last_seen": { "type": "string", "format": "date-time" },
              "total_input": { "type": "integer", "minimum": 0 },
              "total_output": { "type": "integer", "minimum": 0 },
              "cache_read": { "type": "integer", "minimum": 0 },
              "cache_creation": { "type": "integer", "minimum": 0 },
              "turn_count": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },

    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_9_verified_pct",
        "required_followup",
        "time_elapsed_seconds",
        "pr_size_buckets"
      ],
      "properties": {
        "phase_9_verified_pct": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "required_followup": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "time_elapsed_seconds": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "pr_size_buckets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["files_changed", "lines_changed"],
          "properties": {
            "files_changed": { "type": "integer", "minimum": 0 },
            "lines_changed": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
