{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adams-review/schema-v1.json",
  "title": "adams-review artifact (v1)",
  "description": "Canonical machine-state artifact produced by /adams-review and mutated by /adams-review-fix. Codifies DESIGN.md §5 (state model) and §6 (artifact schema). Rev 8.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "generated_at",
    "review_started_at",
    "reviewed_sha",
    "base_branch",
    "head_branch",
    "mode",
    "pr_state",
    "pr_number",
    "comment_id",
    "trivial_mode",
    "reviewer_sources",
    "reviewed_files_all",
    "claude_md_paths",
    "findings",
    "cross_cutting_groups",
    "subagent_tokens",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "review_id": {
      "type": "string",
      "pattern": "^rev_[A-Za-z0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "base_branch": { "type": "string", "minLength": 1 },
    "head_branch": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["pr", "local"] },
    "pr_state": {
      "anyOf": [
        { "enum": ["draft", "open"] },
        { "type": "null" }
      ]
    },
    "pr_number": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "comment_id": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "trivial_mode": { "type": "boolean" },
    "reviewer_sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewed_files_all": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "claude_md_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "cross_cutting_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/cross_cutting_group" }
    },
    "subagent_tokens": { "$ref": "#/$defs/subagent_tokens" },
    "metrics": { "$ref": "#/$defs/metrics" }
  },

  "$defs": {
    "disposition_enum": {
      "enum": [
        "below_gate",
        "disproven",
        "uncertain",
        "confirmed_auto",
        "confirmed_manual",
        "confirmed_report",
        "pre_existing_report",
        "partial",
        "regression",
        "resolved"
      ]
    },
    "current_state_enum": {
      "enum": ["open", "attempted", "resolved"]
    },
    "impact_type_enum": {
      "enum": ["correctness", "security", "ux", "policy", "architecture"]
    },
    "origin_enum": {
      "enum": ["introduced_by_pr", "pre_existing", "unknown"]
    },
    "origin_confidence_enum": {
      "enum": ["high", "medium", "low"]
    },
    "actionability_enum": {
      "enum": ["auto_fixable", "manual", "report_only"]
    },
    "validation_lane_enum": {
      "enum": ["deep", "light"]
    },
    "confirmed_strength_enum": {
      "enum": ["moderate", "strong"]
    },
    "phase_9_outcome_enum": {
      "enum": ["verified", "partial", "regression"]
    },
    "score_phase_enum": {
      "enum": [
        "phase_3",
        "phase_4",
        "phase_4a",
        "phase_4b"
      ]
    },

    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sources",
        "source_families",
        "impact_type",
        "origin",
        "origin_confidence",
        "actionability",
        "validation_lane",
        "current_state",
        "disposition",
        "is_actionable",
        "reason",
        "confirmed_strength",
        "file",
        "line_range",
        "claim",
        "score_phase3",
        "score_phase4",
        "score_history",
        "validation_result",
        "fix_attempts",
        "introduced_in_sha",
        "suggested_follow_up",
        "related_parent_finding_id"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^F[0-9]+$" },
        "sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_families": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "impact_type": { "$ref": "#/$defs/impact_type_enum" },
        "origin": { "$ref": "#/$defs/origin_enum" },
        "origin_confidence": { "$ref": "#/$defs/origin_confidence_enum" },
        "actionability": { "$ref": "#/$defs/actionability_enum" },
        "validation_lane": { "$ref": "#/$defs/validation_lane_enum" },
        "current_state": { "$ref": "#/$defs/current_state_enum" },
        "disposition": { "$ref": "#/$defs/disposition_enum" },
        "is_actionable": { "type": "boolean" },
        "reason": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "confirmed_strength": {
          "anyOf": [
            { "$ref": "#/$defs/confirmed_strength_enum" },
            { "type": "null" }
          ]
        },
        "file": { "type": "string", "minLength": 1 },
        "line_range": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2
        },
        "claim": { "type": "string", "minLength": 1 },
        "score_phase3": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "score_phase4": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "score_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "score"],
            "properties": {
              "phase": { "$ref": "#/$defs/score_phase_enum" },
              "score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "validation_result": {
          "anyOf": [
            { "$ref": "#/$defs/validation_result" },
            { "type": "null" }
          ]
        },
        "fix_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fix_attempt" }
        },
        "introduced_in_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            { "type": "null" }
          ]
        },
        "suggested_follow_up": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "related_parent_finding_id": {
          "anyOf": [
            { "type": "string", "pattern": "^F[0-9]+$" },
            { "type": "null" }
          ]
        }
      }
    },

    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "blast_radius",
        "fix_proposal",
        "verification_context"
      ],
      "properties": {
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blast_radius": {
          "type": "object",
          "additionalProperties": false,
          "required": ["writers", "consumers", "parallel_paths", "invariants_at_stake"],
          "properties": {
            "writers": { "type": "array", "items": { "type": "string" } },
            "consumers": { "type": "array", "items": { "type": "string" } },
            "parallel_paths": { "type": "array", "items": { "type": "string" } },
            "invariants_at_stake": { "type": "array", "items": { "type": "string" } }
          }
        },
        "fix_proposal": { "$ref": "#/$defs/fix_proposal" },
        "verification_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "how_to_verify_fix",
            "edge_cases_to_preserve",
            "what_would_break_if_incomplete"
          ],
          "properties": {
            "how_to_verify_fix": { "type": "array", "items": { "type": "string" } },
            "edge_cases_to_preserve": { "type": "array", "items": { "type": "string" } },
            "what_would_break_if_incomplete": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "fix_proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approach", "files_to_modify"],
      "properties": {
        "approach": { "type": "string", "minLength": 1 },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "what", "why"],
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "what": { "type": "string" },
              "why": { "type": "string" }
            }
          }
        }
      }
    },

    "fix_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "timestamp",
        "fix_group_id",
        "input_sha",
        "output_sha",
        "phase_9_outcome"
      ],
      "properties": {
        "run_id": { "type": "string", "pattern": "^fixrun_[A-Za-z0-9]+$" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fix_group_id": { "type": "string", "pattern": "^FG-[0-9]+$" },
        "input_sha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
        "output_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
            { "type": "null" }
          ]
        },
        "phase_9_outcome": {
          "anyOf": [
            { "$ref": "#/$defs/phase_9_outcome_enum" },
            { "type": "null" }
          ]
        },
        "phase_9_finding": { "type": "string" },
        "revised_fix_proposal": { "$ref": "#/$defs/fix_proposal" }
      }
    },

    "cross_cutting_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "finding_ids", "combined_approach"],
      "properties": {
        "id": { "type": "string", "pattern": "^G[0-9]+$" },
        "finding_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F[0-9]+$" },
          "minItems": 2
        },
        "combined_approach": { "type": "string", "minLength": 1 }
      }
    },

    "subagent_tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "invocations", "by_phase", "by_model", "by_lens", "by_finding_phase4"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "invocations": { "type": "integer", "minimum": 0 },
        "by_phase": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_model": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_lens": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_finding_phase4": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_9_verified_pct",
        "required_followup",
        "time_elapsed_seconds",
        "pr_size_buckets"
      ],
      "properties": {
        "phase_9_verified_pct": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ]
        },
        "required_followup": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "time_elapsed_seconds": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "pr_size_buckets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["files_changed", "lines_changed"],
          "properties": {
            "files_changed": { "type": "integer", "minimum": 0 },
            "lines_changed": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
